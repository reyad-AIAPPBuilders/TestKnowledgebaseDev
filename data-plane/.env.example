# ── Data Plane Settings (DP_ prefix) ──────────────────
DP_HMAC_SECRET=                  # HMAC-SHA256 shared secret (empty = auth disabled)
DP_MODE=on-premise               # "on-premise" or "cloud"
DP_TENANT_ID=wiener-neudorf      # Municipality identifier
DP_WORKER_ID=wn-worker-01        # Worker node identifier
DP_ONLINE_API_KEYS=              # Comma-separated API keys for online endpoints (empty = online disabled)
DP_LOG_LEVEL=info                # debug | info | warning | error
DP_LOG_JSON=true                 # true = structured JSON logs, false = console
DP_CORS_ORIGINS=*                # Comma-separated allowed origins

# ── Jina Reader (fallback scraper) ──────────────────
JINA_API_URL=https://eu-r-beta.jina.ai
JINA_API_KEY=                        # Jina API key (empty = Jina fallback disabled)

# ── Crawl4AI ─────────────────────────────────────────
CRAWL4AI_URL=http://crawl4ai:11235
CRAWL4AI_API_TOKEN=

# ── LlamaParse (cloud document parsing) ──────────────
# Leave LLAMA_CLOUD_API_KEY empty to use the local Unstructured parser instead.
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai/api/v1/parsing
# EU endpoint: https://api.cloud.eu.llamaindex.ai/api/v1/parsing

# ── BGE-M3 (embedding model) ─────────────────────────
BGE_M3_URL=http://bge-m3:8080

# ── Qdrant (vector database) ─────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wiener-neudorf # Default collection name (tenant-based)

# ── Redis (caching & rate limiting) ───────────────────
REDIS_URL=redis://redis:6379/0

# ── LiteLLM (self-hosted proxy for fallback embedding) ──
LITELLM_URL=http://litellm:4000       # LiteLLM proxy URL (OpenAI-compatible /v1/embeddings)
LITELLM_API_KEY=                       # Optional API key for LiteLLM authentication
BGE_GEMMA2_MODEL=nebius/BAAI/bge-multilingual-gemma2  # Model name registered in LiteLLM
BGE_GEMMA2_DENSE_DIM=3584             # Dense vector dimension for BGE-Gemma2 (must match model output)

# ── OpenAI (LLM classification + primary embedding) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── TEI (AT-specific embedding endpoint for /online/ingest/at) ──
# OpenAI-compatible server. POST {TEI_EMBED_URL_AT}/v1/embeddings, bearer auth.
# TEI_EMBED_MODEL_AT is optional — most TEI servers ignore it (one model per process).
TEI_EMBED_URL_AT=https://embed.ki2.at
TEI_EMBED_API_KEY_AT=
TEI_EMBED_MODEL_AT=

# ── ClickHouse (audit logging) ───────────────────────
CLICKHOUSE_REQUIRED=false        # true = fail startup if unreachable
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=ki2_audit
CLICKHOUSE_USER=dataplane
CLICKHOUSE_PASSWORD=

# ── LDAP (on-premise only) ───────────────────────────
LDAP_URL=ldap://dc.example.local
LDAP_BIND_DN=CN=ki2-service,OU=ServiceAccounts,DC=example,DC=local
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=DC=example,DC=local

# ── SMB (on-premise only) ────────────────────────────
SMB_USERNAME=ki2-service
SMB_PASSWORD=
SMB_DOMAIN=EXAMPLE

# ── Cloudflare R2 (cloud only) ───────────────────────
R2_ENDPOINT_URL=https://account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ki2-documents
